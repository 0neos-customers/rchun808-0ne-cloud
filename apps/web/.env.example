# ============================================
# 0ne Cloud Environment Variables
# ============================================

# --- Template Config (customize for your deployment) ---
# Platform admin email — hidden from the customer admin user list but retains
# full admin access for support/debugging. Set by the orchestrator at provision.
NEXT_PUBLIC_PLATFORM_ADMIN_EMAIL=
OWNER_NAME=Your Name
NEXT_PUBLIC_ORG_NAME=Your Organization
SUPPORT_EMAIL=support@example.com
NEXT_PUBLIC_INSTANCE_SLUG=

# --- Database (Neon PostgreSQL) ---
NEON_POSTGRES_URL=

# --- Auth (Better Auth) ---
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=
# Per-instance base URL — e.g. https://your-slug.0neos.com
BETTER_AUTH_URL=http://localhost:3000

# --- OAuth (shared 0ne Cloud Google client) ---
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
# All customer instances funnel Google callbacks through the control plane.
OAUTH_REDIRECT_BASE_URL=https://app.0neos.com

# --- Mailgun (shared transactional sender) ---
MAILGUN_API_KEY=
MAILGUN_DOMAIN=mail.0neos.com
MAILGUN_FROM_EMAIL=noreply@mail.0neos.com

# --- App URL ---
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# --- Cron Security ---
CRON_SECRET=

# --- Subscription Paywall (optional) ---
# URL where users can reactivate (Skool group join page, Stripe portal, etc.)
NEXT_PUBLIC_REACTIVATION_URL=
