{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "bun run build --filter=web",
  "installCommand": "bun install",
  "outputDirectory": "apps/web/.next",
  "framework": "nextjs",
  "redirects": [
    {
      "source": "/podcast",
      "destination": "https://open.spotify.com/playlist/5xFAYhRQQaOnMPbmyq49lf",
      "permanent": true
    }
  ],
  "crons": [
    {
      "path": "/api/cron/sync-ghl",
      "schedule": "0 4 * * *"
    },
    {
      "path": "/api/cron/sync-meta",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/aggregate",
      "schedule": "0 7 * * *"
    },
    {
      "path": "/api/cron/send-daily-snapshot",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron/sync-skool-dms",
      "schedule": "*/5 * * * *"
    }
  ]
}
